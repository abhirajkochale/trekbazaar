# Copy this file to .env.local and fill in your real Supabase values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service_role key (admin panel). Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Single admin password gating /admin (server-only, no NEXT_PUBLIC_).
ADMIN_PASSWORD=
